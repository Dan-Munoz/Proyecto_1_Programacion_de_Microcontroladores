                                 ; ***** BOOTLOADER DECLARATIONS ******************************************
                                 .equ	NRWW_START_ADDR	= 0x3800
                                 .equ	NRWW_STOP_ADDR	= 0x3fff
                                 .equ	RWW_START_ADDR	= 0x0
                                 .equ	RWW_STOP_ADDR	= 0x37ff
                                 .equ	PAGESIZE	= 64
                                 .equ	FIRSTBOOTSTART	= 0x3f00
                                 .equ	SECONDBOOTSTART	= 0x3e00
                                 .equ	THIRDBOOTSTART	= 0x3c00
                                 .equ	FOURTHBOOTSTART	= 0x3800
                                 .equ	SMALLBOOTSTART	= FIRSTBOOTSTART
                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	PCI0addr	= 0x0006	; Pin Change Interrupt Request 0
                                 .equ	PCI1addr	= 0x0008	; Pin Change Interrupt Request 0
                                 .equ	PCI2addr	= 0x000a	; Pin Change Interrupt Request 1
                                 .equ	WDTaddr	= 0x000c	; Watchdog Time-out Interrupt
                                 .equ	OC2Aaddr	= 0x000e	; Timer/Counter2 Compare Match A
                                 .equ	OC2Baddr	= 0x0010	; Timer/Counter2 Compare Match A
                                 .equ	OVF2addr	= 0x0012	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x0014	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x0016	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0018	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x001a	; Timer/Counter1 Overflow
                                 .equ	OC0Aaddr	= 0x001c	; TimerCounter0 Compare Match A
                                 .equ	OC0Baddr	= 0x001e	; TimerCounter0 Compare Match B
                                 .equ	OVF0addr	= 0x0020	; Timer/Couner0 Overflow
                                 .equ	SPIaddr	= 0x0022	; SPI Serial Transfer Complete
                                 .equ	URXCaddr	= 0x0024	; USART Rx Complete
                                 .equ	UDREaddr	= 0x0026	; USART, Data Register Empty
                                 .equ	UTXCaddr	= 0x0028	; USART Tx Complete
                                 .equ	ADCCaddr	= 0x002a	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x002c	; EEPROM Ready
                                 .equ	ACIaddr	= 0x002e	; Analog Comparator
                                 .equ	TWIaddr	= 0x0030	; Two-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0032	; Store Program Memory Read
                                 
                                 .equ	INT_VECTORS_SIZE	= 52	; size in words
                                 
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 * Proyecto1_final.asm
                                 *
                                 * Creado: 28/02/2026 15:11:30
                                 * Autor : Dan Muńoz
                                 * Descripción: Proyecto 1 Programación de Microcontroladores
                                 * Reloj digital de 4 displays de 7 segmentos, que muestran hora en formato 24hrs (00:00 - 23:59), fecha formato DIA DIA:MES MES (01:01 - 31:12)
                                 * además de alarma, todo lo anteriormente mencionado configurable. El reloj consta de 8 modos 0-7 que se muestran a través de 3 leds (B1-B3) y
                                 * la alarma activa un buzzer desactivable mediante cualquiera de los botones incremento/decremento, además
                                 * los dos puntos de los displays se encienden/apagan cada 500ms.
                                 */
                                 /******************************************************************************************************/
                                 // Encabezado (Definición de Registros, Variables y Constantes)
                                 .include "M328PDEF.inc"						// Include definitions specific to ATMega328P
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 .equ	TMR0_VALUE	=	6					// TCNT0
                                 .equ	TMR1_VALUE	=	0x85EE				// TCNT1
                                 .equ	MAX_MODES	=	8					// Limitar los modos a 8 (0-7)
                                 .def	PUNTO		=	R25					// Registro para encender D7 (puntos del display)
                                 
                                 .dseg
                                 //variable_name:     .byte   1   // Memory alocation for variable_name:     .byte   (byte size)
                                 // Variables en RAM
000100                           MULTIPLEXOR		:	.byte 1					// Para multiplexar displays
000101                           DISP_VALUE		:	.byte 1					// Valor que se mostrará en PORTD (display)
000102                           UN_MIN			:	.byte 1					// Unidades de minutos
000103                           DEC_MIN			:	.byte 1					// Decenas de minutos
000104                           UN_HORA			:	.byte 1					// Unidades de hora 
000105                           DEC_HORA		:	.byte 1					// Decenas de hora
000106                           UN_DIA			:	.byte 1					// Unidades de día
000107                           DEC_DIA			:	.byte 1					// Decenas de día
000108                           UN_MES			:	.byte 1					// Unidades de mes
000109                           DEC_MES			:	.byte 1					// Decenas de mes
00010a                           TIEMPO			:	.byte 1					// Contador de 0-120 para timer 1 para esperar 1 minuto
00010b                           ESTADO			:	.byte 1					// Estado de pines C4 y C5 (botones incremento y decremento)
                                 											  
00010c                           MODE			:	.byte 1					// Modo actual
00010d                           CONTAR			:	.byte 1					// Bandera para contar minutos
00010e                           MULTIPLEXION	:	.byte 1					// Bandera para cambiar la multiplexion de los displays
00010f                           INCREMENTAR		:	.byte 1					// Bandera para incrementar dependiendo el modo
000110                           DECREMENTAR		:	.byte 1					// Bandera para decrementar dependiendo el modo
000111                           UN_MIN_ALARMA	:	.byte 1					// Unidades de minutos de alarma
000112                           DEC_MIN_ALARMA	:	.byte 1					// Decenas de minutos de alarma
000113                           UN_HORA_ALARMA	:	.byte 1					// Unidades de hora de alarma
000114                           DEC_HORA_ALARMA	:	.byte 1					// Decenas de hora de alarma
000115                           ALARMA			:	.byte 1					// Bandera para activar el buzzer
                                 
                                 .cseg
                                 .org 0x0000									// Vector de inicio
000000 940c 002e                 	JMP START								
                                 .org PCI0addr								// Vector de interrupción pin change pin B0
000006 940c 0402                 	JMP PINB_ISR							
                                 .org PCI1addr								// Vector de interrupción pin change pin C4-C5
000008 940c 0415                 	JMP PINC_ISR							
                                 .org OVF1addr								// Vector de interrupción overflow timer 1
00001a 940c 043e                 	JMP TMR1_ISR							
                                 .org OVF0addr								// Vector de interrupción overflow timer 0
000020 940c 0430                 	JMP TMR0_ISR
                                 
                                  /*****************************************************************************************************/
                                 // Configuración de la pila
000022 ef0f                      	LDI     R16, LOW(RAMEND)
000023 bf0d                      	OUT     SPL, R16
000024 e008                      	LDI     R16, HIGH(RAMEND)
000025 bf0e                      	OUT     SPH, R16
                                 
                                 // Tabla de valores Display 7 segmentos (0-F)
000026 063f
000027 4f5b
000028 6d66
000029 077d
00002a 6f7f
00002b 7c77
00002c 5e39
00002d 7179                      table7seg: .DB 0x3F,0x06,0x5B,0x4F,0x66,0x6D,0x7D,0x07,0x7F,0x6F,0x77,0x7C,0x39,0x5E,0x79,0x71
                                 
                                 /******************************************************************************************************/
                                 // Configuracion MCU
                                 START:
                                 	// Disable interruptions
00002e 94f8                      	CLI
                                 	// Define Entradas y Salidas
                                 	// Puerto B
00002f e20e                      	LDI	R16, (1 << DDB1) | (1 << DDB2) | (1 << DDB3) | (1 << DDB5)
000030 b904                      	OUT	DDRB, R16							// B0 botón, B1-B3 leds de modo y B5 buzzer
000031 e001                      	LDI	R16, (1 << PB0)
000032 b905                      	OUT	PORTB, R16							// Pullup en B0
                                 	// Puerto C
000033 e00f                      	LDI R16, (1 << DDC0) | (1 << DDC1) | (1 << DDC2) | (1 << DDC3)
000034 b907                      	OUT DDRC, R16							// C0-C3 para multiplexar displays y C4-C5 para
000035 ef0f                      	LDI R16, 0xFF							// botones incremento/decremento
000036 b908                      	OUT PORTC, R16							// Pullup en C4-C5
                                 	// Puerto D
000037 ef0f                      	LDI R16, 0xFF
000038 b90a                      	OUT DDRD, R16							// D0-D7 para mostrar valores de displays
000039 2700                      	CLR R16
00003a b90b                      	OUT PORTD, R16
                                 	// Apagar UART RX/TX
00003b e000                      	LDI  R16, 0x00
00003c 9300 00c1                     STS  UCSR0B, R16 	
                                 
                                 	// Inicialización de timers
00003e 940e 03ee                 	CALL	INIT_TMR1
000040 940e 03fb                 	CALL	INIT_TMR0
                                 
                                 	// Limpiar registros y cargar variables
000042 2799                      	CLR	PUNTO
000043 e00e                      	LDI R16, 0b00001110						// Cargar valor para multiplexar diplay 0
000044 9300 0100                 	STS MULTIPLEXOR, R16
                                 	
                                 	// Guardar 00 en minutos y horas
000046 e000                      	LDI R16, 0x00
000047 9300 0102                 	STS UN_MIN, R16
000049 9300 0103                 	STS DEC_MIN, R16
00004b 9300 0104                 	STS UN_HORA, R16
00004d 9300 0105                 	STS DEC_HORA, R16
00004f 9300 0107                 	STS DEC_DIA, R16
000051 9300 0109                 	STS DEC_MES, R16
000053 9300 0101                 	STS DISP_VALUE, R16
                                 	// Configurar alarma para 00:00 por default
000055 9300 0111                 	STS	UN_MIN_ALARMA, R16	
000057 9300 0112                 	STS	DEC_MIN_ALARMA, R16
000059 9300 0113                 	STS	UN_HORA_ALARMA, R16
00005b 9300 0114                 	STS	DEC_HORA_ALARMA, R16
                                 
00005d 9300 010d                 	STS	CONTAR, R16							// Apagar bandera para incrementar minutos
00005f 9300 010c                 	STS MODE, R16							// Iniciar en modo 0
000061 9300 010e                 	STS	MULTIPLEXION, R16					// Apagar bandera para multiplexar
000063 9300 010f                 	STS	INCREMENTAR, R16					// Apagar bandera para incrementar
000065 9300 0110                 	STS	DECREMENTAR, R16					// Apagar bandera para decrementar
                                 	// Guardar fecha en 01:01
000067 e001                      	LDI	R16, 0X01
000068 9300 0106                 	STS UN_DIA, R16
00006a 9300 0108                 	STS UN_MES, R16
                                 	// Leer C4-C5 y guardarlos en ESTADO
00006c b106                      	IN R16, PINC							           
00006d 7300                          ANDI R16, 0b00110000
00006e 9300 010b                     STS ESTADO, R16
                                 
                                 	// Habilitar interrupciones
                                 	// Timer 1
000070 e001                      	LDI		R16, (1 << TOIE1)
000071 9300 006f                 	STS		TIMSK1, R16
                                 	// Timer 0
000073 e001                      	LDI		R16, (1 << TOIE0)
000074 9300 006e                 	STS		TIMSK0, R16
                                 	// PC4(INCREMENTAR) y PC5(DECREMENTAR)
000076 e003                      	LDI		R16, (1 << PCIE1) | (1 << PCIE0)
000077 9300 0068                 	STS		PCICR, R16
000079 e300                      	LDI		R16, (1 << PCINT12) | (1 << PCINT13)
00007a 9300 006c                 	STS		PCMSK1, R16
                                 	// PB5 (MODO)
00007c e001                      	LDI		R16, (1 << PCINT0)
00007d 9300 006b                 	STS		PCMSK0, R16
00007f 2700                      	CLR		R16
000080 9478                      	SEI
                                 	
                                 /*************************************************** LOOP ***********************************************/
                                 /* Revisa el modo seleccionado y salta a la subrutina correspondiente, pasa a la subrutina
                                 * de multiplexación, muestra el valor en el display seleccionado, revisa si la alarma
                                 * está activada y muestra el modo actual en los leds.
                                 */
                                 MAIN_LOOP:
                                 // Verificar modo actual
                                 VERIFY_MODE0:
000081 9100 010c                 	LDS		R16, MODE
000083 3000                      	CPI		R16, 0x00
000084 f409                      	BRNE	VERIFY_MODE1					
000085 c02d                      	RJMP	MODE_0							// Saltar a subrutina de modo 0
                                 VERIFY_MODE1:
000086 3001                      	CPI		R16, 0x01
000087 f409                      	BRNE	VERIFY_MODE2
000088 c0ed                      	RJMP	MODE_1							// Saltar a subrutina de modo 1
                                 VERIFY_MODE2:
000089 3002                      	CPI		R16, 0x02
00008a f409                      	BRNE	VERIFY_MODE3
00008b c0eb                      	RJMP	MODE_2							// Saltar a subrutina de modo 2
                                 VERIFY_MODE3:
00008c 3003                      	CPI		R16, 0x03
00008d f409                      	BRNE	VERIFY_MODE4
00008e c121                      	RJMP	MODE_3							// Saltar a subrutina de modo 3
                                 VERIFY_MODE4:
00008f 3004                      	CPI		R16, 0x04
000090 f409                      	BRNE	VERIFY_MODE5
000091 c163                      	RJMP	MODE_4							// Saltar a subrutina de modo 4
                                 VERIFY_MODE5:
000092 3005                      	CPI		R16, 0x05
000093 f409                      	BRNE	VERIFY_MODE6
000094 c1ba                      	RJMP	MODE_5							// Saltar a subrutina de modo 5
                                 VERIFY_MODE6:
000095 3006                      	CPI		R16, 0x06
000096 f409                      	BRNE	VERIFY_MODE7
000097 c24b                      	RJMP	MODE_6							// Saltar a subrutina de modo 6
                                 VERIFY_MODE7:
000098 3007                      	CPI		R16, 0x07
000099 f409                      	BRNE	MULTIPLEXAR
00009a c281                      	RJMP	MODE_7							// Saltar a subrutina de modo 7
                                 
                                 MULTIPLEXAR:
00009b c2c5                      	RJMP	MULTIPLEXACION					// Saltar a subrutina de multiplexación
                                 
                                 MOSTRAR:
00009c 9100 0100                 	LDS		R16, MULTIPLEXOR
00009e 6300                      	ORI		R16, 0b00110000
00009f b908                      	OUT		PORTC, R16						// Encender display correspondiente
                                 
0000a0 9100 0101                 	LDS		R16, DISP_VALUE					// Bajar a R16 el valor del display
0000a2 e0f0                      	LDI		ZH, HIGH(table7seg<<1)			// Ubicarse en el primer valor de la tabla
0000a3 e4ec                      	LDI		ZL, LOW(table7seg<<1)	
0000a4 0fe0                      	ADD		ZL, R16							// Sumamos a la dirección 0 de la tabla el valor del display
0000a5 9114                      	LPM		R17, Z							// Bajamos el valor de la tabla a R17
0000a6 2b19                      	OR		R17, PUNTO						// Encendemos/apagamos dos puntos
0000a7 b91b                      	OUT		PORTD, R17						// Mostramos valor en display
                                 
                                 	// Verificar si bandera ALARMA está encendida y mostrar modo
0000a8 9100 010c                 	LDS		R16, MODE
0000aa 0f00                      	LSL		R16
0000ab 6001                      	ORI		R16, 0x01
0000ac 9110 0115                 	LDS		R17, ALARMA
0000ae 3011                      	CPI		R17, 0x01
0000af f409                      	BRNE	MOSTRAR_MODO
0000b0 6200                      	ORI		R16, 0b00100000					// Si ALARMA = 0x01 encender buzzer
                                 
                                 MOSTRAR_MODO:
0000b1 b905                      	OUT		PORTB, R16						// Mostrar modo actual en leds
                                 
0000b2 cfce                          RJMP    MAIN_LOOP
                                 
                                 
                                 /*********************************************** MODOS **************************************************/
                                 
                                 /*********************************************** MODO_0 ************************************************/
                                 /* Revisa si el timer 1 ya encendió la bandera CONTAR para incrementar minutos, si sí, incrementa
                                 * minutos y horas (00:00 - 23:59), y al llegar a 00:00 aumentar días y meses (01:01 - 31:12).
                                 */
                                 MODE_0:
0000b3 94f8                      	CLI										// Desactivar interrupciones momentáneamente para poder apagar bandera
0000b4 9100 010d                 	LDS		R16, CONTAR
0000b6 3001                      	CPI		R16, 0x01						// Revisar si CONTAR = 1 para incrementar hora
0000b7 f429                      	BRNE	NO_INCREMENTO
                                 	// Limpiar variable CONTAR
0000b8 2700                      	CLR		R16
0000b9 9300 010d                 	STS		CONTAR, R16						// Limpiar bandera contar
0000bb 9478                      	SEI
0000bc c002                      	RJMP	CARGAR_VALORES
                                 NO_INCREMENTO:								// Salir de subrutina de modo
0000bd 9478                      	SEI
0000be c09c                      	RJMP	EXIT_CONTAR_TIEMPO
                                 CARGAR_VALORES:
                                 // Cargar valores de hora y fecha en registros de propósito general
0000bf 9110 0102                 	LDS		R17, UN_MIN
0000c1 9120 0103                 	LDS		R18, DEC_MIN
0000c3 9130 0104                 	LDS		R19, UN_HORA
0000c5 9140 0105                 	LDS		R20, DEC_HORA
0000c7 9150 0106                 	LDS		R21, UN_DIA
0000c9 9160 0107                 	LDS		R22, DEC_DIA
0000cb 9170 0108                 	LDS		R23, UN_MES
0000cd 9180 0109                 	LDS		R24, DEC_MES
                                 
0000cf 9513                      	INC		R17								// Incrementar unidades de minutos
0000d0 301a                      	CPI		R17, 10							// Si ya pasaron 10 minutos incrementar decenas de minutos
0000d1 f009                      	BREQ	SUMAR_DEC_MIN	
0000d2 c05d                      	RJMP	GUARDAR_TMR1_ISR
                                 SUMAR_DEC_MIN:
0000d3 2711                      	CLR		R17								// Limpiar unidades de  minutos
0000d4 9523                      	INC		R18								// Incrementar decenas de minutos
0000d5 3026                      	CPI		R18, 6							// Si ya pasaron 60 minutos incrementar unidades de hora
0000d6 f009                      	BREQ	SUMAR_UN_HORA
0000d7 c058                      	RJMP	GUARDAR_TMR1_ISR
                                 SUMAR_UN_HORA:								
0000d8 2722                      	CLR		R18								// Limpiar decenas de minutos
0000d9 9533                      	INC		R19								// Incrementar unidades de hora
0000da 3034                      	CPI		R19, 4							// Si unidades de hora = 4 ir a rutina de verificación cambio de dia
0000db f029                      	BREQ	VERIFY_CAMBIO_DIA
0000dc 303a                      	CPI		R19, 10							// Si ya pasaron 10 horas incrementar decenas de hora
0000dd f009                      	BREQ	SUMAR_DEC_HORA
0000de c051                      	RJMP	GUARDAR_TMR1_ISR
                                 SUMAR_DEC_HORA:
0000df 2733                      	CLR		R19								// Limpiar unidades de hora
0000e0 9543                      	INC		R20								// Incrementar decenas de hora
                                 VERIFY_CAMBIO_DIA:
                                 // Rutina para verificar cambio de día
0000e1 3034                      	CPI		R19, 4
0000e2 f009                      	BREQ	COMPARAR_DEC_HORA
0000e3 c04c                      	RJMP	GUARDAR_TMR1_ISR
                                 COMPARAR_DEC_HORA:
0000e4 3042                      	CPI		R20, 2
0000e5 f009                      	BREQ	LIMPIAR_HORA
0000e6 c049                      	RJMP	GUARDAR_TMR1_ISR
                                 LIMPIAR_HORA:								// Si decenas de hora = 2 y unidades de hora = 4 cambiar de dia
0000e7 2733                      	CLR		R19								// Limpiar unidades de hora
0000e8 2744                      	CLR		R20								// Limpiar decenas de hora
                                 
0000e9 3081                      	CPI		R24, 1							// Revisar decenas de meses para revisar 3 meses primeros o 9 finales
0000ea f009                      	BREQ	TRES_MESES_FINALES
0000eb c003                      	RJMP	NUEVE_MESES_PRIMEROS
                                 
                                 TRES_MESES_FINALES:
0000ec 3071                      	CPI		R23, 1							// Si es noviembre saltar a rutina de 30 días, si no saltar a 31 días
0000ed f131                      	BREQ	TREINTA_DIAS
0000ee c017                      	RJMP	TREINTA_Y_UN_DIAS
                                 
                                 NUEVE_MESES_PRIMEROS:
0000ef 3072                      	CPI		R23, 2							// Si es febrero saltar a rutina de 28 días
0000f0 f039                      	BREQ	VEINTIOCHO_DIAS
0000f1 3074                      	CPI		R23, 4							// Si es abril saltar a rutina de 30 días
0000f2 f109                      	BREQ	TREINTA_DIAS
0000f3 3076                      	CPI		R23, 6							// Si es junio saltar a rutina de 30 días
0000f4 f0f9                      	BREQ	TREINTA_DIAS
0000f5 3079                      	CPI		R23, 9							// Si es septiembre saltar a rutina de 30 días
0000f6 f0e9                      	BREQ	TREINTA_DIAS
0000f7 c00e                      	RJMP	TREINTA_Y_UN_DIAS				// Resto de meses 1x saltar a rutina de 31 días
                                 
                                 /* Rutina que aumenta día hasta 28 y luego aumenta mes*/
                                 VEINTIOCHO_DIAS:
0000f8 9553                      	INC		R21
0000f9 3059                      	CPI		R21, 9							// Si la unidad de día incrementó a 9 verificar si ya llego a 29 para cambiar mes
0000fa f021                      	BREQ	VERIFY_CAMBIO_MES3
0000fb 305a                      	CPI		R21, 10							// Aumentar decena de día
0000fc f599                      	BRNE	GUARDAR_TMR1_ISR
0000fd 2755                      	CLR		R21
0000fe 9563                      	INC		R22
                                 // Revisar si día incrementó a 29 para limpiar a 01 y cambiar mes
                                 VERIFY_CAMBIO_MES3:
0000ff 3059                      	CPI		R21, 9
000100 f579                      	BRNE	GUARDAR_TMR1_ISR
000101 3062                      	CPI		R22, 2
000102 f569                      	BRNE	GUARDAR_TMR1_ISR
000103 e051                      	LDI		R21, 0x01
000104 2766                      	CLR		R22
000105 c01c                      	RJMP	CAMBIO_MES
                                 
                                 /* Rutina que aumenta día hasta 31 y luego aumenta mes*/
                                 TREINTA_Y_UN_DIAS:
000106 9553                      	INC		R21
000107 3052                      	CPI		R21, 2							// Si la unidad de día aumentó a 2 revisar si llegó a 32 para cambiar mes
000108 f021                      	BREQ	VERIFY_CAMBIO_MES2
000109 305a                      	CPI		R21, 10							// Aumentar decena de día
00010a f529                      	BRNE	GUARDAR_TMR1_ISR
00010b 2755                      	CLR		R21
00010c 9563                      	INC		R22
                                 // Revisar si día incrementó a 32 para reiniciar a 01 y aumentar mes
                                 VERIFY_CAMBIO_MES2:
00010d 3052                      	CPI		R21, 2
00010e f509                      	BRNE	GUARDAR_TMR1_ISR
00010f 3063                      	CPI		R22, 3
000110 f4f9                      	BRNE	GUARDAR_TMR1_ISR
000111 e051                      	LDI		R21, 0x01
000112 2766                      	CLR		R22
000113 c00e                      	RJMP	CAMBIO_MES
                                 
                                 /* Rutina que aumenta día hasta 30 y luego aumenta mes*/
                                 TREINTA_DIAS:
000114 9553                      	INC		R21
000115 3051                      	CPI		R21, 1							// Si la unidad de día aumentó a 1 revisar si llegó a 31 para cambiar de mes
000116 f021                      	BREQ	VERIFY_CAMBIO_MES1
000117 305a                      	CPI		R21, 10							// Aumentar decena de día
000118 f4b9                      	BRNE	GUARDAR_TMR1_ISR
000119 2755                      	CLR		R21
00011a 9563                      	INC		R22
                                 // Revisar si día incrementó a 31 para reiniciar a 01 y aumentar mes
                                 VERIFY_CAMBIO_MES1:
00011b 3051                      	CPI		R21, 1
00011c f499                      	BRNE	GUARDAR_TMR1_ISR
00011d 3063                      	CPI		R22, 3
00011e f489                      	BRNE	GUARDAR_TMR1_ISR
00011f e051                      	LDI		R21, 0x01
000120 2766                      	CLR		R22
000121 c000                      	RJMP	CAMBIO_MES
                                 
                                 /* Aumento de mes con overflow cuando llega a 13 (01-12)*/
                                 CAMBIO_MES:
000122 9573                      	INC		R23
000123 3073                      	CPI		R23, 3
000124 f021                      	BREQ	VERIFY_DICIEMBRE
000125 307a                      	CPI		R23, 10
000126 f449                      	BRNE	GUARDAR_TMR1_ISR
000127 2777                      	CLR		R23
000128 9583                      	INC		R24
                                 VERIFY_DICIEMBRE:
000129 3073                      	CPI		R23, 3
00012a f429                      	BRNE	GUARDAR_TMR1_ISR
00012b 3081                      	CPI		R24, 1
00012c f419                      	BRNE	GUARDAR_TMR1_ISR
00012d e071                      	LDI		R23, 1
00012e 2788                      	CLR		R24
00012f c000                      	RJMP	GUARDAR_TMR1_ISR
                                 
                                 /* Guardar los valores de minutos, horas, día y mes en las variables*/
                                 GUARDAR_TMR1_ISR:
000130 9310 0102                 	STS		UN_MIN, R17
000132 9320 0103                 	STS		DEC_MIN, R18
000134 9330 0104                 	STS		UN_HORA, R19
000136 9340 0105                 	STS		DEC_HORA, R20
000138 9350 0106                 	STS		UN_DIA, R21
00013a 9360 0107                 	STS		DEC_DIA, R22
00013c 9370 0108                 	STS		UN_MES, R23
00013e 9380 0109                 	STS		DEC_MES, R24
                                 
                                 /* Verificar si la hora configurada de la alarma coincide con la hora actual*/
                                 ALARMA_Y_MODO:
                                 	// Cargar variables a registros de propósito general
000140 9100 0102                 	LDS		R16, UN_MIN
000142 9110 0111                 	LDS		R17, UN_MIN_ALARMA
000144 9120 0103                 	LDS		R18, DEC_MIN
000146 9130 0112                 	LDS		R19, DEC_MIN_ALARMA
000148 9140 0104                 	LDS		R20, UN_HORA
00014a 9150 0113                 	LDS		R21, UN_HORA_ALARMA
00014c 9160 0105                 	LDS		R22, DEC_HORA
00014e 9170 0114                 	LDS		R23, DEC_HORA_ALARMA
                                 	// Revisar si cada valor coincide
000150 1701                      	CP		R16, R17
000151 f449                      	BRNE	EXIT_CONTAR_TIEMPO
000152 1723                      	CP		R18, R19
000153 f439                      	BRNE	EXIT_CONTAR_TIEMPO
000154 1745                      	CP		R20, R21
000155 f429                      	BRNE	EXIT_CONTAR_TIEMPO
000156 1767                      	CP		R22, R23
000157 f419                      	BRNE	EXIT_CONTAR_TIEMPO
                                 	// Si minutos y horas coinciden guardar 1 en alarma
000158 e001                      	LDI		R16, 0x01
000159 9300 0115                 	STS		ALARMA, R16
                                 
                                 /* Revisar si la variable bandera de los botones incremento y decremento está en 1 para cargar 0 a alarma */
                                 EXIT_CONTAR_TIEMPO:
00015b 94f8                      	CLI
                                 	// Revisar botón 1
00015c 9100 010f                 	LDS		R16, INCREMENTAR
00015e 3001                      	CPI		R16, 0x01
00015f f429                      	BRNE	NO_BOTON1_MODE0	
                                 	// Limpiar bandera INCREMENTAR
000160 2700                      	CLR		R16
000161 9300 010f                 	STS		INCREMENTAR, R16
000163 9478                      	SEI
000164 c00d                      	RJMP	APAGAR_ALARMA_MODE0
                                 NO_BOTON1_MODE0:
000165 9478                      	SEI
000166 94f8                      	CLI
                                 	// Revisar botón 2
000167 9100 0110                 	LDS		R16, DECREMENTAR
000169 3001                      	CPI		R16, 0x01
00016a f429                      	BRNE	NO_BOTON2_MODE0
                                 	// Limpiar bandera DECREMENTAR
00016b 2700                      	CLR		R16
00016c 9300 0110                 	STS		DECREMENTAR, R16
00016e 9478                      	SEI
00016f c002                      	RJMP	APAGAR_ALARMA_MODE0
                                 // Si ninguno está presionado salir
                                 NO_BOTON2_MODE0:
000170 9478                      	SEI
000171 c003                      	RJMP	EXIT_MODE_0
                                 // Si algún botón está presionado cargar 0 a variable ALARMA
                                 APAGAR_ALARMA_MODE0:
000172 e000                      	LDI		R16, 0x00
000173 9300 0115                 	STS		ALARMA, R16
                                 /* Salida del modo */
                                 EXIT_MODE_0:
000175 cf25                      	RJMP	MULTIPLEXAR
                                 
                                 
                                 /************************************************* MODO_1 ***********************************************/
                                 /* Modo que muestra fecha, pero la función es la misma que el modo 0 (aumentar hora), por lo que se salta a la
                                 subrutina de MODE_0 para que siga aumentando el tiempo */
                                 MODE_1:
                                 	// Salto a MODE_0 para segir contando
000176 cf3c                      	RJMP	MODE_0
                                 
                                 
                                 /************************************************* MODO_2 ***********************************************/
                                 /* Modo encargado de modificar minutos, revisa si las banderas (variables) incrementar o decrementar
                                 están encendidas para incrementar o decrementar minutos */
                                 MODE_2:
000177 94f8                      	CLI
                                 	// Revisar si INCREMENTAR = 1
000178 9100 010f                 	LDS		R16, INCREMENTAR
00017a 3001                      	CPI		R16, 0x01
00017b f429                      	BRNE	NO_INCREMENTAR_MIN	
                                 	// Limpiar bandera
00017c 2700                      	CLR		R16
00017d 9300 010f                 	STS		INCREMENTAR, R16
00017f 9478                      	SEI
000180 c00d                      	RJMP	INCREMENTAR_MIN
                                 NO_INCREMENTAR_MIN:
000181 9478                      	SEI
000182 94f8                      	CLI
                                 	// Revisar si DECREMENTAR = 1
000183 9100 0110                 	LDS		R16, DECREMENTAR
000185 3001                      	CPI		R16, 0x01
000186 f429                      	BRNE	NO_DECREMENTAR_MIN
                                 	// Limpiar bandera
000187 2700                      	CLR		R16
000188 9300 0110                 	STS		DECREMENTAR, R16
00018a 9478                      	SEI
00018b c013                      	RJMP	DECREMENTAR_MIN
                                 // Si ninguna bandera de botón está encendida salir del modo
                                 NO_DECREMENTAR_MIN:
00018c 9478                      	SEI
00018d c021                      	RJMP	EXIT_MODE_2
                                 
                                 /* Incrementar minutos*/
                                 INCREMENTAR_MIN:
                                 	// Cargar variables de minutos a registros de propósito general
00018e 9110 0102                 	LDS		R17, UN_MIN
000190 9120 0103                 	LDS		R18, DEC_MIN
000192 9513                      	INC		R17								// Incrementar unidades de minutos
000193 301a                      	CPI		R17, 10							// Aumentar decenas de minutos
000194 f429                      	BRNE	GUARDAR_INC_MIN
000195 2711                      	CLR		R17
000196 9523                      	INC		R18
000197 3026                      	CPI		R18, 6							// Si llegó a 60 resetear
000198 f409                      	BRNE	GUARDAR_INC_MIN
000199 2722                      	CLR		R18
                                 GUARDAR_INC_MIN:
                                 	// Guardar valores de minutos
00019a 9310 0102                 	STS		UN_MIN, R17
00019c 9320 0103                 	STS		DEC_MIN, R18
00019e c010                      	RJMP	EXIT_MODE_2
                                 
                                 /* Decrementar minutos */
                                 DECREMENTAR_MIN:
                                 	// Cargar valores de minutos a registros de propósito general
00019f 9110 0102                 	LDS		R17, UN_MIN
0001a1 9120 0103                 	LDS		R18, DEC_MIN
0001a3 951a                      	DEC		R17								// Decrementar unidades de minutos
0001a4 3f1f                      	CPI		R17, 255						// Decrementar decenas de minutos
0001a5 f429                      	BRNE	GUARDAR_DEC_MIN
0001a6 e019                      	LDI		R17, 9
0001a7 952a                      	DEC		R18
0001a8 3f2f                      	CPI		R18, 255						// Si llegó a 00 resetear
0001a9 f409                      	BRNE	GUARDAR_DEC_MIN
0001aa e025                      	LDI		R18, 5
                                 GUARDAR_DEC_MIN:
                                 	// Guardar valores de minutos
0001ab 9310 0102                 	STS		UN_MIN, R17
0001ad 9320 0103                 	STS		DEC_MIN, R18
                                 
                                 /* Salida Modo 2 */
                                 EXIT_MODE_2:
0001af ceeb                      	RJMP	MULTIPLEXAR
                                 
                                 
                                 /************************************************** MODO_3 ***********************************************/
                                 /* Modo encargado de modificar horas, según esté encendida la bandera INCREMENTAR o DECREMENTAR */
                                 MODE_3:
0001b0 94f8                      	CLI
                                 	// Revisar si INCREMENTAR = 1
0001b1 9100 010f                 	LDS		R16, INCREMENTAR
0001b3 3001                      	CPI		R16, 0x01
0001b4 f429                      	BRNE	NO_INCREMENTAR_HORA	
                                 	// Limpiar bandera
0001b5 2700                      	CLR		R16
0001b6 9300 010f                 	STS		INCREMENTAR, R16
0001b8 9478                      	SEI
0001b9 c00d                      	RJMP	INCREMENTAR_HORA
                                 NO_INCREMENTAR_HORA:
0001ba 9478                      	SEI
0001bb 94f8                      	CLI
                                 	// Revisar si DECREMENTAR = 1
0001bc 9100 0110                 	LDS		R16, DECREMENTAR
0001be 3001                      	CPI		R16, 0x01
0001bf f429                      	BRNE	NO_DECREMENTAR_HORA	
                                 	// Limpiar bandera
0001c0 2700                      	CLR		R16
0001c1 9300 0110                 	STS		DECREMENTAR, R16
0001c3 9478                      	SEI
0001c4 c01b                      	RJMP	DECREMENTAR_HORA
                                 // Si no está encendida ninguna bandera, salir
                                 NO_DECREMENTAR_HORA:
0001c5 9478                      	SEI
0001c6 c02d                      	RJMP	EXIT_MODE_3
                                 
                                 /* Incrementar hora */
                                 INCREMENTAR_HORA:
                                 	// Cargar valores de hora en registros de propósito general
0001c7 9110 0104                 	LDS		R17, UN_HORA
0001c9 9120 0105                 	LDS		R18, DEC_HORA
0001cb 9513                      	INC		R17								// Incrementar unidades de hora
0001cc 3014                      	CPI		R17, 4							// Si unidades de hora incrementó a 4 revisar si llegó a 24
0001cd f029                      	BREQ	VERIFY_24HRS
0001ce 301a                      	CPI		R17, 10							// Incrementar decenas de hora
0001cf f009                      	BREQ	INCREMENTAR_DEC_HORA
0001d0 c00a                      	RJMP	GUARDAR_INC_HORA
                                 INCREMENTAR_DEC_HORA:
0001d1 2711                      	CLR		R17
0001d2 9523                      	INC		R18
                                 // Revisar si horas = 24 para reiniciar hora
                                 VERIFY_24HRS:
0001d3 3014                      	CPI		R17, 4
0001d4 f009                      	BREQ	COMPARAR_DEC_HORA_INC
0001d5 c005                      	RJMP	GUARDAR_INC_HORA
                                 COMPARAR_DEC_HORA_INC:
0001d6 3022                      	CPI		R18, 2
0001d7 f009                      	BREQ	LIMPIAR_HORA_INC
0001d8 c002                      	RJMP	GUARDAR_INC_HORA
                                 // Al llegar a 24:00 reiniciar hora (00:00)
                                 LIMPIAR_HORA_INC:
0001d9 2711                      	CLR		R17
0001da 2722                      	CLR		R18
                                 // Guardar valores de hora
                                 GUARDAR_INC_HORA:
0001db 9310 0104                 	STS		UN_HORA, R17
0001dd 9320 0105                 	STS		DEC_HORA, R18
0001df c014                      	RJMP	EXIT_MODE_3
                                 
                                 /* Si está encendida la bandera de decrementar, decrementar hora hasta 00:00 y luego pasar a 23:59 */
                                 DECREMENTAR_HORA:
                                 	// Cargar valores de hora a registros de propósito general
0001e0 9110 0104                 	LDS		R17, UN_HORA
0001e2 9120 0105                 	LDS		R18, DEC_HORA
0001e4 951a                      	DEC		R17								// Decrementar unidades de hora
0001e5 3f1f                      	CPI		R17, 255						// Si unidades de hora = 0 decrementar decenas de hora
0001e6 f009                      	BREQ	DECREMENTAR_DEC_HORA
0001e7 c007                      	RJMP	GUARDAR_DEC_HORA
                                 DECREMENTAR_DEC_HORA:
0001e8 e019                      	LDI		R17, 9
0001e9 952a                      	DEC		R18								// Decrementar decenas de hora
0001ea 3f2f                      	CPI		R18, 255						// Si unidades de hora = 0 reiniciar hora
0001eb f009                      	BREQ	LIMPIAR_HORA_DEC
0001ec c002                      	RJMP	GUARDAR_DEC_HORA
                                 // Reiniciar hora (23:59)
                                 LIMPIAR_HORA_DEC:
0001ed e013                      	LDI		R17, 3
0001ee e022                      	LDI		R18, 2
                                 // Guardar valores de hora
                                 GUARDAR_DEC_HORA:
0001ef 9310 0104                 	STS		UN_HORA, R17
0001f1 9320 0105                 	STS		DEC_HORA, R18
0001f3 c000                      	RJMP	EXIT_MODE_3
                                 	
                                 EXIT_MODE_3:
0001f4 cea6                      	RJMP	MULTIPLEXAR
                                 
                                 
                                 /************************************************* MODO_4 ************************************************/
                                 /* Modo encargado de modificar meses según la bandera de botón activada (si se modifica el mes se
                                  resetea el día a 01) */
                                 MODE_4:
0001f5 94f8                      	CLI
                                 	// Revisar si bandera Incrementar = 1
0001f6 9100 010f                 	LDS		R16, INCREMENTAR
0001f8 3001                      	CPI		R16, 0x01
0001f9 f429                      	BRNE	NO_INCREMENTAR_MES	
                                 	// Limpiar bandera
0001fa 2700                      	CLR		R16
0001fb 9300 010f                 	STS		INCREMENTAR, R16
0001fd 9478                      	SEI
0001fe c00d                      	RJMP	INCREMENTAR_MES
                                 NO_INCREMENTAR_MES:
0001ff 9478                      	SEI
000200 94f8                      	CLI
                                 	// Revisar si bandera Decrementar = 1
000201 9100 0110                 	LDS		R16, DECREMENTAR
000203 3001                      	CPI		R16, 0x01
000204 f429                      	BRNE	NO_DECREMENTAR_MES	
                                 	// Limpiar bandera
000205 2700                      	CLR		R16
000206 9300 0110                 	STS		DECREMENTAR, R16
000208 9478                      	SEI
000209 c025                      	RJMP	DECREMENTAR_MES
                                 // Si ambas banderas son 0 salir
                                 NO_DECREMENTAR_MES:
00020a 9478                      	SEI
00020b c042                      	RJMP	EXIT_MODE_4
                                 
                                 /* Incrementar mes */
                                 INCREMENTAR_MES:
                                 	// Cargar valores de mes y día
00020c 9130 0106                 	LDS		R19, UN_DIA						
00020e e031                      	LDI		R19, 0x01						// Cargar 01 a día
00020f 9140 0107                 	LDS		R20, DEC_DIA					
000211 2744                      	CLR		R20								
000212 9110 0108                 	LDS		R17, UN_MES
000214 9120 0109                 	LDS		R18, DEC_MES
000216 9513                      	INC		R17								// Incrementar unidades de mes
000217 3013                      	CPI		R17, 3							// Si un_mes incrementó a 3 revisar si ya se pasó de 12 para reiniciar
000218 f029                      	BREQ	VERIFY_MES12
000219 301a                      	CPI		R17, 10							// Si un_mes incrementó a 10 poner 0 y aumentar dec_mes
00021a f009                      	BREQ	INCREMENTAR_DEC_MES
00021b c00a                      	RJMP	GUARDAR_INC_MES
                                 INCREMENTAR_DEC_MES:
00021c 2711                      	CLR		R17
00021d 9523                      	INC		R18								// Incrementar dec_mes
                                 // Revisar si mes llegó a 13 para reiniciar a 01
                                 VERIFY_MES12:
00021e 3013                      	CPI		R17, 3
00021f f009                      	BREQ	COMPARAR_DEC_MES_INC
000220 c005                      	RJMP	GUARDAR_INC_MES
                                 COMPARAR_DEC_MES_INC:
000221 3021                      	CPI		R18, 1
000222 f009                      	BREQ	LIMPIAR_MES_INC
000223 c002                      	RJMP	GUARDAR_INC_MES
                                 LIMPIAR_MES_INC:
000224 e011                      	LDI		R17, 0x01						// Cargar mes 01
000225 2722                      	CLR		R18
                                 GUARDAR_INC_MES:
                                 	// Guardar valores de mes y día
000226 9330 0106                 	STS		UN_DIA, R19						
000228 9340 0107                 	STS		DEC_DIA, R20					
00022a 9310 0108                 	STS		UN_MES, R17
00022c 9320 0109                 	STS		DEC_MES, R18
00022e c01f                      	RJMP	EXIT_MODE_4
                                 
                                 /* Decrementar mes */
                                 DECREMENTAR_MES:
                                 	// Cargar valores de mes y día
00022f 9130 0106                 	LDS		R19, UN_DIA						// Cargar 01 a día
000231 e031                      	LDI		R19, 0x01						
000232 9140 0107                 	LDS		R20, DEC_DIA					
000234 2744                      	CLR		R20								
000235 9110 0108                     LDS  R17, UN_MES
000237 9120 0109                     LDS  R18, DEC_MES
                                 
                                     // Si mes llegó a 01 siguiente es 12
000239 3011                          CPI  R17, 1
00023a f429                          BRNE NORMAL_DEC_CHECK
00023b 3020                          CPI  R18, 0
00023c f419                          BRNE NORMAL_DEC_CHECK
                                 
                                     // Cargar 12
00023d e012                          LDI  R17, 2
00023e e021                          LDI  R18, 1
00023f c005                          RJMP GUARDAR_DEC_MES
                                 
                                 NORMAL_DEC_CHECK:
000240 951a                          DEC  R17								// Decrementar un_mes
000241 3f1f                          CPI  R17, 255							// Si un_mes llegó a 0 cargar 9 y decrementar dec_mes
000242 f411                          BRNE GUARDAR_DEC_MES
                                 
000243 e019                          LDI  R17, 9
000244 952a                          DEC  R18								// Decrementar dec_mes
                                 
                                 GUARDAR_DEC_MES:
                                 	// Guardar valores de día y mes
000245 9330 0106                 	STS	 UN_DIA, R19						
000247 9340 0107                 	STS	 DEC_DIA, R20					
000249 9310 0108                     STS  UN_MES, R17
00024b 9320 0109                     STS  DEC_MES, R18
00024d c000                          RJMP EXIT_MODE_4
                                 	
                                 EXIT_MODE_4:
00024e ce4c                      	RJMP	MULTIPLEXAR
                                 
                                 
                                 /************************************************** MODO_5 ************************************************/
                                 /* Modo encargado de modificar día del mes actual según la bandera incrementar o decrementar */
                                 MODE_5:
00024f 94f8                      	CLI
                                 	// Revisar si bandera Incrementar = 1
000250 9100 010f                 	LDS		R16, INCREMENTAR
000252 3001                      	CPI		R16, 0x01
000253 f429                      	BRNE	NO_INCREMENTAR_DIA	
                                 	// Limpiar bandera
000254 2700                      	CLR		R16
000255 9300 010f                 	STS		INCREMENTAR, R16
000257 9478                      	SEI
000258 c00d                      	RJMP	INCREMENTAR_DIA
                                 NO_INCREMENTAR_DIA:
000259 9478                      	SEI
00025a 94f8                      	CLI
                                 	// Revisar si bandera Decrementar = 1
00025b 9100 0110                 	LDS		R16, DECREMENTAR
00025d 3001                      	CPI		R16, 0x01
00025e f429                      	BRNE	NO_DECREMENTAR_DIA
                                 	// Limpiar bandera
00025f 2700                      	CLR		R16
000260 9300 0110                 	STS		DECREMENTAR, R16
000262 9478                      	SEI
000263 c04c                      	RJMP	DECREMENTAR_DIA
                                 // Si ninguna bandera está encendida, salir
                                 NO_DECREMENTAR_DIA:
000264 9478                      	SEI
000265 c07c                      	RJMP	EXIT_MODE_5
                                 
                                 /* Incrementar día */
                                 INCREMENTAR_DIA:
                                 	// Cargar valores de mes y día a registros de propósito general
000266 9100 0106                 	LDS		R16, UN_DIA
000268 9110 0107                 	LDS		R17, DEC_DIA
00026a 9120 0108                 	LDS		R18, UN_MES
00026c 9130 0109                 	LDS		R19, DEC_MES
                                 
                                 	// Revisar si dec_mes = 1 para saber si son los primeros 9 meses o los últimos 3
00026e 3031                      	CPI		R19, 1
00026f f009                      	BREQ	TRES_MESES_FINALES_INC_DIA
000270 c003                      	RJMP	NUEVE_MESES_PRIMEROS_INC_DIA
                                 
                                 // Revisar 3 meses finales
                                 TRES_MESES_FINALES_INC_DIA:
000271 3021                      	CPI		R18, 1
000272 f131                      	BREQ	TREINTA_DIAS_INC_DIA			// Si es nov ir a subrutina de 30 días
000273 c017                      	RJMP	TREINTA_Y_UN_DIAS_INC_DIA		// Los otros ir a subrutina de 31 días
                                 
                                 // Revisar 9 meses primeros
                                 NUEVE_MESES_PRIMEROS_INC_DIA:
000274 3022                      	CPI		R18, 2
000275 f039                      	BREQ	VEINTIOCHO_DIAS_INC_DIA			// Si es feb ir a subrutina de 28 días
000276 3024                      	CPI		R18, 4
000277 f109                      	BREQ	TREINTA_DIAS_INC_DIA			// Si es abr ir a subrutina de 30 días
000278 3026                      	CPI		R18, 6	
000279 f0f9                      	BREQ	TREINTA_DIAS_INC_DIA			// Si es jun ir a subrutina de 30 días
00027a 3029                      	CPI		R18, 9
00027b f0e9                      	BREQ	TREINTA_DIAS_INC_DIA			// Si es sept ir a subrutina de 30 días
00027c c00e                      	RJMP	TREINTA_Y_UN_DIAS_INC_DIA		// El resto ir a subrutina de 31 días
                                 
                                 // Subrutina de 28 días de límite
                                 VEINTIOCHO_DIAS_INC_DIA:
00027d 9503                      	INC		R16
00027e 3009                      	CPI		R16, 9
00027f f021                      	BREQ	VERIFY_CAMBIO_MES3_INC_DIA
000280 300a                      	CPI		R16, 10
000281 f529                      	BRNE	GUARDAR_INC_DIA
000282 2700                      	CLR		R16
000283 9513                      	INC		R17
                                 // Revisar si incrementó a 29 para reiniciar
                                 VERIFY_CAMBIO_MES3_INC_DIA:
000284 3009                      	CPI		R16, 9
000285 f509                      	BRNE	GUARDAR_INC_DIA
000286 3012                      	CPI		R17, 2
000287 f4f9                      	BRNE	GUARDAR_INC_DIA
000288 e001                      	LDI		R16, 0x01
000289 2711                      	CLR		R17
00028a c01c                      	RJMP	GUARDAR_INC_DIA
                                 
                                 // Subrutina de 31 días de límite
                                 TREINTA_Y_UN_DIAS_INC_DIA:
00028b 9503                      	INC		R16
00028c 3002                      	CPI		R16, 2
00028d f021                      	BREQ	VERIFY_CAMBIO_MES2_INC_DIA
00028e 300a                      	CPI		R16, 10
00028f f4b9                      	BRNE	GUARDAR_INC_DIA
000290 2700                      	CLR		R16
000291 9513                      	INC		R17
                                 // Si incrementó a 32 reiniciar
                                 VERIFY_CAMBIO_MES2_INC_DIA:
000292 3002                      	CPI		R16, 2
000293 f499                      	BRNE	GUARDAR_INC_DIA
000294 3013                      	CPI		R17, 3
000295 f489                      	BRNE	GUARDAR_INC_DIA
000296 e001                      	LDI		R16, 0x01
000297 2711                      	CLR		R17
000298 c00e                      	RJMP	GUARDAR_INC_DIA
                                 
                                 // Subrutina de 30 días de límite
                                 TREINTA_DIAS_INC_DIA:
000299 9503                      	INC		R16
00029a 3001                      	CPI		R16, 1
00029b f021                      	BREQ	VERIFY_CAMBIO_MES1_INC_DIA
00029c 300a                      	CPI		R16, 10
00029d f449                      	BRNE	GUARDAR_INC_DIA
00029e 2700                      	CLR		R16
00029f 9513                      	INC		R17
                                 // Si incrementó a 31 reiniciar
                                 VERIFY_CAMBIO_MES1_INC_DIA:
0002a0 3001                      	CPI		R16, 1
0002a1 f429                      	BRNE	GUARDAR_INC_DIA
0002a2 3013                      	CPI		R17, 3
0002a3 f419                      	BRNE	GUARDAR_INC_DIA
0002a4 e001                      	LDI		R16, 0x01
0002a5 2711                      	CLR		R17
0002a6 c000                      	RJMP	GUARDAR_INC_DIA
                                 
                                 GUARDAR_INC_DIA:
                                 	// Guardar valores
0002a7 9300 0106                 	STS		UN_DIA, R16
0002a9 9310 0107                 	STS		DEC_DIA, R17
0002ab 9320 0108                 	STS		UN_MES, R18
0002ad 9330 0109                 	STS		DEC_MES, R19
0002af c032                      	RJMP EXIT_MODE_5
                                 
                                 /* Decrementar día con underflow correspondiente al mes */
                                 DECREMENTAR_DIA:
0002b0 9100 0106                     LDS     R16, UN_DIA
0002b2 9110 0107                     LDS     R17, DEC_DIA
0002b4 9120 0108                     LDS     R18, UN_MES
0002b6 9130 0109                     LDS     R19, DEC_MES
                                 
                                     // Si no ha llegado a 01 solo decrementar hasta llegar a 01
0002b8 3001                          CPI     R16, 1
0002b9 f4d1                          BRNE    NORMAL_DEC_DIA
0002ba 3010                          CPI     R17, 0
0002bb f4c1                          BRNE    NORMAL_DEC_DIA
                                 
                                 	// Si ya llegó a 01 revisar el mes para hacer underflow correspondiente
0002bc 3031                          CPI     R19, 1
0002bd f009                          BREQ    TRES_MESES_FINALES_DEC_DIA		// Revisar 9 primeros meses
0002be c003                          RJMP    NUEVE_MESES_PRIMEROS_DEC_DIA	// Revisar últimos 3 meses
                                 
                                 // Revisar últimos 3 meses
                                 TRES_MESES_FINALES_DEC_DIA:
0002bf 3021                          CPI     R18, 1
0002c0 f069                          BREQ    CARGAR_30						// Si es nov ir a subrutina de 30 días
0002c1 c00f                          RJMP    CARGAR_31						// Los otros ir a subrutina de 31 días
                                 
                                 // Revisar primeros 9 meses
                                 NUEVE_MESES_PRIMEROS_DEC_DIA:
0002c2 3022                          CPI     R18, 2							
0002c3 f039                          BREQ    CARGAR_28						// Si es feb ir a subrutina de 28 días
0002c4 3024                          CPI     R18, 4
0002c5 f041                          BREQ    CARGAR_30						// Si es abr ir a subrutina de 30 días
0002c6 3026                          CPI     R18, 6
0002c7 f031                          BREQ    CARGAR_30						// Si es jun ir a subrutina de 30 días
0002c8 3029                          CPI     R18, 9
0002c9 f021                          BREQ    CARGAR_30						// Si es sept ir a subrutina de 30 días
0002ca c006                          RJMP    CARGAR_31						// El resto ir a subrutina de 31 días
                                 
                                 // Subrutina para cargar 28
                                 CARGAR_28:
0002cb e008                          LDI     R16, 8
0002cc e012                          LDI     R17, 2
0002cd c00b                          RJMP    GUARDAR_DEC_DIA
                                 
                                 // Subrutina para cargar 30
                                 CARGAR_30:
0002ce e000                          LDI     R16, 0
0002cf e013                          LDI     R17, 3
0002d0 c008                          RJMP    GUARDAR_DEC_DIA
                                 
                                 // Subrutina para cargar 31
                                 CARGAR_31:
0002d1 e001                          LDI     R16, 1
0002d2 e013                          LDI     R17, 3
0002d3 c005                          RJMP    GUARDAR_DEC_DIA
                                 
                                 // Decremento normal de día hasta llegar a 01
                                 NORMAL_DEC_DIA:
0002d4 950a                          DEC     R16
0002d5 3f0f                          CPI     R16, 255
0002d6 f411                          BRNE    GUARDAR_DEC_DIA
0002d7 e009                          LDI     R16, 9
0002d8 951a                          DEC     R17
                                 
                                 GUARDAR_DEC_DIA:
                                 	// Guardar valores de día y mes
0002d9 9300 0106                     STS     UN_DIA, R16
0002db 9310 0107                     STS     DEC_DIA, R17
0002dd 9320 0108                     STS     UN_MES, R18
0002df 9330 0109                     STS     DEC_MES, R19
0002e1 c000                          RJMP    EXIT_MODE_5
                                 
                                 EXIT_MODE_5:
0002e2 cdb8                      	RJMP	MULTIPLEXAR
                                 
                                 
                                 /************************************************* MODO_6 *************************************************/
                                 /* Modificar valores de minutos de alarma según la bandera de incremento o decremento activada */
                                 MODE_6:
0002e3 94f8                      	CLI
                                 	// Revisar si Incrementar = 1
0002e4 9100 010f                 	LDS		R16, INCREMENTAR
0002e6 3001                      	CPI		R16, 0x01
0002e7 f429                      	BRNE	NO_INCREMENTAR_MIN_ALARMA	
                                 	// Limpiar bandera
0002e8 2700                      	CLR		R16
0002e9 9300 010f                 	STS		INCREMENTAR, R16
0002eb 9478                      	SEI
0002ec c00d                      	RJMP	INCREMENTAR_MIN_ALARMA
                                 NO_INCREMENTAR_MIN_ALARMA:
0002ed 9478                      	SEI
0002ee 94f8                      	CLI
                                 	// Revisar si Decrementar = 1
0002ef 9100 0110                 	LDS		R16, DECREMENTAR
0002f1 3001                      	CPI		R16, 0x01
0002f2 f429                      	BRNE	NO_DECREMENTAR_MIN_ALARMA	
                                 	// Limpiar bandera
0002f3 2700                      	CLR		R16
0002f4 9300 0110                 	STS		DECREMENTAR, R16
0002f6 9478                      	SEI
0002f7 c013                      	RJMP	DECREMENTAR_MIN_ALARMA
                                 // Si ninguna bandera está encendida, salir
                                 NO_DECREMENTAR_MIN_ALARMA:
0002f8 9478                      	SEI
0002f9 c021                      	RJMP	EXIT_MODE_6
                                 
                                 /* Incrementar minutos de alarma */
                                 INCREMENTAR_MIN_ALARMA:
                                 	// Cargar valores a registros
0002fa 9110 0111                 	LDS		R17, UN_MIN_ALARMA
0002fc 9120 0112                 	LDS		R18, DEC_MIN_ALARMA
0002fe 9513                      	INC		R17								// Incrementar unidades de minutos
0002ff 301a                      	CPI		R17, 10							// Si llegó a 10 incrementar decenas de minutos
000300 f429                      	BRNE	GUARDAR_INC_MIN_ALARMA
000301 2711                      	CLR		R17
000302 9523                      	INC		R18								// Incrementar decenas de minutos
000303 3026                      	CPI		R18, 6							// Si llegó a 6 reiniciar
000304 f409                      	BRNE	GUARDAR_INC_MIN_ALARMA
000305 2722                      	CLR		R18
                                 // Guardar valores y salir
                                 GUARDAR_INC_MIN_ALARMA:
000306 9310 0111                 	STS		UN_MIN_ALARMA, R17
000308 9320 0112                 	STS		DEC_MIN_ALARMA, R18
00030a c010                      	RJMP	EXIT_MODE_6
                                 
                                 /* Decrementar minutos de alarma */
                                 DECREMENTAR_MIN_ALARMA:
                                 	// Cargar valores a registros
00030b 9110 0111                 	LDS		R17, UN_MIN_ALARMA
00030d 9120 0112                 	LDS		R18, DEC_MIN_ALARMA
00030f 951a                      	DEC		R17								// Decrementar unidades de minutos
000310 3f1f                      	CPI		R17, 255						// Si llegó a 0 cargar 9 y restar dec de minutos
000311 f429                      	BRNE	GUARDAR_DEC_MIN_ALARMA
000312 e019                      	LDI		R17, 9
000313 952a                      	DEC		R18								// Decrementar decenas de minutos
000314 3f2f                      	CPI		R18, 255
000315 f409                      	BRNE	GUARDAR_DEC_MIN_ALARMA
000316 e025                      	LDI		R18, 5							// Si llegó a 0 cargar 5
                                 
                                 // Guardar valores
                                 GUARDAR_DEC_MIN_ALARMA:
000317 9310 0111                 	STS		UN_MIN_ALARMA, R17
000319 9320 0112                 	STS		DEC_MIN_ALARMA, R18
                                 	
                                 EXIT_MODE_6:
00031b cd7f                      	RJMP	MULTIPLEXAR
                                 
                                 
                                 /************************************************* MODO_7 ************************************************/
                                 /* Modo encargado de modificar las horas de alarma según está encendida incrementar o decrementar */
                                 MODE_7:
00031c 94f8                      	CLI
                                 	// Revisar si Incrementar = 1
00031d 9100 010f                 	LDS		R16, INCREMENTAR
00031f 3001                      	CPI		R16, 0x01
000320 f429                      	BRNE	NO_INCREMENTAR_HORA_ALARMA
                                 	// Limpiar bandera
000321 2700                      	CLR		R16
000322 9300 010f                 	STS		INCREMENTAR, R16
000324 9478                      	SEI
000325 c00d                      	RJMP	INCREMENTAR_HORA_ALARMA
                                 NO_INCREMENTAR_HORA_ALARMA:
000326 9478                      	SEI
000327 94f8                      	CLI
                                 	// Revisar si Decrementar = 1
000328 9100 0110                 	LDS		R16, DECREMENTAR
00032a 3001                      	CPI		R16, 0x01
00032b f429                      	BRNE	NO_DECREMENTAR_HORA_ALARMA
                                 	// Limpiar bandera
00032c 2700                      	CLR		R16
00032d 9300 0110                 	STS		DECREMENTAR, R16
00032f 9478                      	SEI
000330 c01b                      	RJMP	DECREMENTAR_HORA_ALARMA
                                 // Si ninguna bandera 
                                 NO_DECREMENTAR_HORA_ALARMA:
000331 9478                      	SEI
000332 c02d                      	RJMP	EXIT_MODE_7
                                 
                                 /* Incrementar hora de alarma */
                                 INCREMENTAR_HORA_ALARMA:
                                 	// Cargar valores de hora de alarma a registros
000333 9110 0113                 	LDS		R17, UN_HORA_ALARMA
000335 9120 0114                 	LDS		R18, DEC_HORA_ALARMA
000337 9513                      	INC		R17								// Incrementar unidades de hora
000338 3014                      	CPI		R17, 4							// Si llegó a 4 revisar si decenas = 2 para reiniciar hora
000339 f029                      	BREQ	VERIFY_24HRS_ALARMA
00033a 301a                      	CPI		R17, 10							// Si llegó a 10 poner en 0 e incrementar decenas
00033b f009                      	BREQ	INCREMENTAR_DEC_HORA_ALARMA
00033c c00a                      	RJMP	GUARDAR_INC_HORA_ALARMA
                                 INCREMENTAR_DEC_HORA_ALARMA:
00033d 2711                      	CLR		R17
00033e 9523                      	INC		R18								// Incrementar decenas de hora
                                 
                                 // Verificar si llegó a 24 horas para reiniciar a 00
                                 VERIFY_24HRS_ALARMA:
00033f 3014                      	CPI		R17, 4
000340 f009                      	BREQ	COMPARAR_DEC_HORA_INC_ALARMA
000341 c005                      	RJMP	GUARDAR_INC_HORA_ALARMA
                                 COMPARAR_DEC_HORA_INC_ALARMA:
000342 3022                      	CPI		R18, 2
000343 f009                      	BREQ	LIMPIAR_HORA_INC_ALARMA
000344 c002                      	RJMP	GUARDAR_INC_HORA_ALARMA
                                 // Limpiar
                                 LIMPIAR_HORA_INC_ALARMA:
000345 2711                      	CLR		R17
000346 2722                      	CLR		R18
                                 
                                 // Guardar valores
                                 GUARDAR_INC_HORA_ALARMA:
000347 9310 0113                 	STS		UN_HORA_ALARMA, R17
000349 9320 0114                 	STS		DEC_HORA_ALARMA, R18
00034b c014                      	RJMP	EXIT_MODE_7
                                 
                                 /* Decrementar hora de alarma */
                                 DECREMENTAR_HORA_ALARMA:
                                 	// Cargar valores de hora de alarma a registros
00034c 9110 0113                 	LDS		R17, UN_HORA_ALARMA
00034e 9120 0114                 	LDS		R18, DEC_HORA_ALARMA
000350 951a                      	DEC		R17								// Decrementar unidades de hora
000351 3f1f                      	CPI		R17, 255						// Llegó a 0 poner en 9 y decrementar decenas de hora
000352 f009                      	BREQ	DECREMENTAR_DEC_HORA_ALARMA
000353 c007                      	RJMP	GUARDAR_DEC_HORA_ALARMA
                                 DECREMENTAR_DEC_HORA_ALARMA:
000354 e019                      	LDI		R17, 9
000355 952a                      	DEC		R18								// Decrementar decenas de hora
000356 3f2f                      	CPI		R18, 255						// Si llegó a 0 reiniciar
000357 f009                      	BREQ	LIMPIAR_HORA_DEC_ALARMA
000358 c002                      	RJMP	GUARDAR_DEC_HORA_ALARMA
                                 // Reiniciar hora (23)
                                 LIMPIAR_HORA_DEC_ALARMA:
000359 e013                      	LDI		R17, 3
00035a e022                      	LDI		R18, 2
                                 
                                 // Guardar valores
                                 GUARDAR_DEC_HORA_ALARMA:
00035b 9310 0113                 	STS		UN_HORA_ALARMA, R17
00035d 9320 0114                 	STS		DEC_HORA_ALARMA, R18
00035f c000                      	RJMP	EXIT_MODE_7
                                 	
                                 EXIT_MODE_7:
000360 cd3a                      	RJMP	MULTIPLEXAR
                                 
                                 
                                 /******************************************* MULTIPLEXACION **********************************************/
                                 /* Subrutina encargada de cambiar de display encendido cada 4ms cuando timer0 enciende la bandera MULTIPLEXION */
                                 MULTIPLEXACION:
000361 94f8                      	CLI
                                 	// Revisar si la bandera Multiplexion = 1 para cambiar de display encendido
000362 9100 010e                 	LDS		R16, MULTIPLEXION
000364 3001                      	CPI		R16, 0x01
000365 f429                      	BRNE	NO_MULTIPLEXAR	
                                 	// Limpiar bandera
000366 2700                      	CLR		R16
000367 9300 010e                 	STS		MULTIPLEXION, R16
000369 9478                      	SEI
00036a c002                      	RJMP	MULTIPLEXAR_VALORES
                                 // Si la bandera no está encendida salir
                                 NO_MULTIPLEXAR:
00036b 9478                      	SEI
00036c c080                      	RJMP	EXIT_MULTIPLEXACION
                                 
                                 // Multiplexar
                                 MULTIPLEXAR_VALORES:
                                 // Revisar el modo actual para ver que valor se debe mostrar (hora, fecha u hora de alarma)
                                 MULTIPLEXAR_MODE0:
00036d 9100 010c                 	LDS		R16, MODE
00036f 3000                      	CPI		R16, 0x00
000370 f409                      	BRNE	MULTIPLEXAR_MODE1	
000371 c016                      	RJMP	VALORES_MODE_0					// Saltar a multiplexar valores de modo 0 
                                 MULTIPLEXAR_MODE1:
000372 3001                      	CPI		R16, 0x01
000373 f409                      	BRNE	MULTIPLEXAR_MODE2
000374 c014                      	RJMP	VALORES_MODE_1					// Saltar a multiplexar valores de modo 1
                                 MULTIPLEXAR_MODE2:
000375 3002                      	CPI		R16, 0x02
000376 f409                      	BRNE	MULTIPLEXAR_MODE3
000377 c012                      	RJMP	VALORES_MODE_2					// Saltar a multiplexar valores de modo 2
                                 MULTIPLEXAR_MODE3:
000378 3003                      	CPI		R16, 0x03
000379 f409                      	BRNE	MULTIPLEXAR_MODE4
00037a c010                      	RJMP	VALORES_MODE_3					// Saltar a multiplexar valores de modo 3
                                 MULTIPLEXAR_MODE4:
00037b 3004                      	CPI		R16, 0x04
00037c f409                      	BRNE	MULTIPLEXAR_MODE5
00037d c00e                      	RJMP	VALORES_MODE_4					// Saltar a multiplexar valores de modo 4
                                 MULTIPLEXAR_MODE5:
00037e 3005                      	CPI		R16, 0x05
00037f f409                      	BRNE	MULTIPLEXAR_MODE6
000380 c00c                      	RJMP	VALORES_MODE_5					// Saltar a multiplexar valores de modo 5
                                 MULTIPLEXAR_MODE6:
000381 3006                      	CPI		R16, 0x06
000382 f409                      	BRNE	MULTIPLEXAR_MODE7
000383 c00a                      	RJMP	VALORES_MODE_6					// Saltar a multiplexar valores de modo 6
                                 MULTIPLEXAR_MODE7:
000384 3007                      	CPI		R16, 0x07
000385 f409                      	BRNE	SALIDA
000386 c008                      	RJMP	VALORES_MODE_7					// Saltar a multiplexar valores de modo 7
                                 SALIDA:
000387 c065                      	RJMP	EXIT_MULTIPLEXACION
                                 
                                 // Si es modo 0 multiplexar valores de hora
                                 VALORES_MODE_0:
000388 c007                      	RJMP MOSTRAR_HORA
                                 
                                 // Si es modo 1 multiplexar valores de fecha
                                 VALORES_MODE_1:
000389 c025                      	RJMP MOSTRAR_DIA
                                 
                                 // Si es modo 2 multiplexar valores de hora
                                 VALORES_MODE_2:
00038a c005                      	RJMP MOSTRAR_HORA
                                 
                                 // Si es modo 3 multiplexar valores de hora
                                 VALORES_MODE_3:
00038b c004                      	RJMP MOSTRAR_HORA
                                 
                                 // Si es modo 4 multiplexar valores de fecha
                                 VALORES_MODE_4:
00038c c022                      	RJMP MOSTRAR_DIA
                                 
                                 // Si es modo 5 multiplexar valores de fecha
                                 VALORES_MODE_5:
00038d c021                      	RJMP MOSTRAR_DIA
                                 
                                 // Si es modo 6 multiplexar valores de hora de alarma
                                 VALORES_MODE_6:
00038e c03f                      	RJMP MOSTRAR_HORA_ALARMA
                                 
                                 // Si es modo 7 multiplexar valores de hora de alarma
                                 VALORES_MODE_7:
00038f c03e                      	RJMP MOSTRAR_HORA_ALARMA
                                 
                                 // Multiplexar valores de hora
                                 MOSTRAR_HORA:
000390 9100 0100                 	LDS		R16, MULTIPLEXOR
000392 300e                      	CPI		R16, 0b00001110
000393 f051                      	BREQ	CAMBIO_C1_HORA
000394 300d                      	CPI		R16, 0b00001101
000395 f061                      	BREQ	CAMBIO_C2_HORA
000396 300b                      	CPI		R16, 0b00001011
000397 f071                      	BREQ	CAMBIO_C3_HORA
000398 3007                      	CPI		R16, 0b00000111
000399 f001                      	BREQ	CAMBIO_C0_HORA
                                 CAMBIO_C0_HORA:
00039a e00e                      	LDI		R16, 0b00001110
00039b 9110 0102                 	LDS		R17, UN_MIN
00039d c00c                      	RJMP GUARDAR_VALORES_HORA
                                 CAMBIO_C1_HORA:
00039e e00d                      	LDI		R16, 0b00001101
00039f 9110 0103                 	LDS		R17, DEC_MIN
0003a1 c008                      	RJMP GUARDAR_VALORES_HORA
                                 CAMBIO_C2_HORA:
0003a2 e00b                      	LDI		R16, 0b00001011
0003a3 9110 0104                 	LDS		R17, UN_HORA
0003a5 c004                      	RJMP GUARDAR_VALORES_HORA
                                 CAMBIO_C3_HORA:
0003a6 e007                      	LDI		R16, 0b00000111
0003a7 9110 0105                 	LDS		R17, DEC_HORA
0003a9 c000                      	RJMP GUARDAR_VALORES_HORA
                                 GUARDAR_VALORES_HORA:
0003aa 9300 0100                 	STS		MULTIPLEXOR, R16
0003ac 9310 0101                 	STS		DISP_VALUE, R17
0003ae c03e                      	RJMP EXIT_MULTIPLEXACION
                                 
                                 // Multiplexar valores de fecha
                                 MOSTRAR_DIA:
0003af 9100 0100                 	LDS		R16, MULTIPLEXOR
0003b1 300e                      	CPI		R16, 0b00001110
0003b2 f051                      	BREQ	CAMBIO_C1_DIA
0003b3 300d                      	CPI		R16, 0b00001101
0003b4 f061                      	BREQ	CAMBIO_C2_DIA
0003b5 300b                      	CPI		R16, 0b00001011
0003b6 f071                      	BREQ	CAMBIO_C3_DIA
0003b7 3007                      	CPI		R16, 0b00000111
0003b8 f001                      	BREQ	CAMBIO_C0_DIA
                                 CAMBIO_C0_DIA:
0003b9 e00e                      	LDI		R16, 0b00001110
0003ba 9110 0108                 	LDS		R17, UN_MES
0003bc c00c                      	RJMP GUARDAR_VALORES_DIA
                                 CAMBIO_C1_DIA:
0003bd e00d                      	LDI		R16, 0b00001101
0003be 9110 0109                 	LDS		R17, DEC_MES
0003c0 c008                      	RJMP GUARDAR_VALORES_DIA
                                 CAMBIO_C2_DIA:
0003c1 e00b                      	LDI		R16, 0b00001011
0003c2 9110 0106                 	LDS		R17, UN_DIA
0003c4 c004                      	RJMP GUARDAR_VALORES_DIA
                                 CAMBIO_C3_DIA:
0003c5 e007                      	LDI		R16, 0b00000111
0003c6 9110 0107                 	LDS		R17, DEC_DIA
0003c8 c000                      	RJMP GUARDAR_VALORES_DIA
                                 GUARDAR_VALORES_DIA:
0003c9 9300 0100                 	STS		MULTIPLEXOR, R16
0003cb 9310 0101                 	STS		DISP_VALUE, R17
0003cd c01f                      	RJMP EXIT_MULTIPLEXACION
                                 
                                 // Multiplexar valores de hora de alarma
                                 MOSTRAR_HORA_ALARMA:
0003ce 9100 0100                 	LDS		R16, MULTIPLEXOR
0003d0 300e                      	CPI		R16, 0b00001110
0003d1 f051                      	BREQ	CAMBIO_C1_HORA_ALARMA
0003d2 300d                      	CPI		R16, 0b00001101
0003d3 f061                      	BREQ	CAMBIO_C2_HORA_ALARMA
0003d4 300b                      	CPI		R16, 0b00001011
0003d5 f071                      	BREQ	CAMBIO_C3_HORA_ALARMA
0003d6 3007                      	CPI		R16, 0b00000111
0003d7 f001                      	BREQ	CAMBIO_C0_HORA_ALARMA
                                 CAMBIO_C0_HORA_ALARMA:
0003d8 e00e                      	LDI		R16, 0b00001110
0003d9 9110 0111                 	LDS		R17, UN_MIN_ALARMA
0003db c00c                      	RJMP GUARDAR_VALORES_HORA_ALARMA
                                 CAMBIO_C1_HORA_ALARMA:
0003dc e00d                      	LDI		R16, 0b00001101
0003dd 9110 0112                 	LDS		R17, DEC_MIN_ALARMA
0003df c008                      	RJMP GUARDAR_VALORES_HORA_ALARMA
                                 CAMBIO_C2_HORA_ALARMA:
0003e0 e00b                      	LDI		R16, 0b00001011
0003e1 9110 0113                 	LDS		R17, UN_HORA_ALARMA
0003e3 c004                      	RJMP GUARDAR_VALORES_HORA_ALARMA
                                 CAMBIO_C3_HORA_ALARMA:
0003e4 e007                      	LDI		R16, 0b00000111
0003e5 9110 0114                 	LDS		R17, DEC_HORA_ALARMA
0003e7 c000                      	RJMP GUARDAR_VALORES_HORA_ALARMA
                                 GUARDAR_VALORES_HORA_ALARMA:
0003e8 9300 0100                 	STS		MULTIPLEXOR, R16
0003ea 9310 0101                 	STS		DISP_VALUE, R17
0003ec c000                      	RJMP EXIT_MULTIPLEXACION
                                 
                                 EXIT_MULTIPLEXACION:
0003ed ccae                      	RJMP	MOSTRAR
                                 	
                                 
                                 /*********************************************************************************************************/
                                 // NON-Interrupt subroutines
                                 // INICIALIZACIÓN TIMER 1 (500ms)
                                 INIT_TMR1:
0003ee 2700                      	CLR		R16
0003ef 9300 0080                 	STS		TCCR1A, R16						// Configuración modo normal
0003f1 e004                      	LDI		R16, (1 << CS12)				// Prescaler 256
0003f2 9300 0081                 	STS		TCCR1B, R16
0003f4 e805                      	LDI		R16, HIGH(TMR1_VALUE)			// Cargar valor TCNT1
0003f5 9300 0085                 	STS		TCNT1H, R16							
0003f7 ee0e                      	LDI		R16, LOW(TMR1_VALUE)				
0003f8 9300 0084                 	STS		TCNT1L, R16							
0003fa 9508                      	RET
                                 
                                 // INICIALIZACIÓN TIMER 0 (4ms)
                                 INIT_TMR0:
0003fb 2700                      	CLR		R16
0003fc bd04                      	OUT		TCCR0A, R16						// Configuración modo normal
0003fd e004                      	LDI		R16, (1 << CS02)				// Prescaler 256
0003fe bd05                      	OUT		TCCR0B , R16					// Cargar valor TCNT0
0003ff e006                      	LDI		R16, TMR0_VALUE					
000400 bd06                      	OUT		TCNT0, R16						
000401 9508                      	RET
                                 
                                 
                                 /**********************************************************************************************************/
                                 // Interrupt routines
                                 // Pin Change Pin B0
                                 PINB_ISR:
000402 930f                      	PUSH R16								// Guardar R16
000403 b70f                          IN   R16, SREG							// Guardar Status Register
000404 930f                          PUSH R16
000405 b103                          IN   R16, PINB							// Leer Pin B
000406 ff00                          SBRS R16, PB0							// Si B0 está en 1, salir de rutina
000407 c001                          RJMP AUMENTAR_MODE						// Aumentar modo
000408 c008                          RJMP EXIT_PINB_ISR
                                 // Aumentar MODE
                                 AUMENTAR_MODE:
000409 9100 010c                     LDS  R16, MODE							// Cargar MODE a R16
00040b 9503                          INC  R16								// Incremntar MODE
00040c 3008                          CPI  R16, MAX_MODES						// Limitar MODE a MAX_MODES (8)
00040d f008                          BRLO GUARDAR_MODE
00040e 2700                          CLR  R16
                                 GUARDAR_MODE:
00040f 9300 010c                     STS MODE, R16							// Guardar R16 en MODE
                                 // Salida ISR
                                 EXIT_PINB_ISR:
000411 910f                          POP  R16								
000412 bf0f                          OUT  SREG, R16							// Cargar SREG
000413 910f                          POP  R16								// Cargar R16
000414 9518                      	RETI
                                 
                                 // Pin Change Pin C4-C5
                                 PINC_ISR:
000415 b70f                      	IN		R16, SREG						// Guardar R16
000416 930f                      	PUSH	R16								// Guardar Status Register
000417 b106                      	IN R16, PINC							// Lectura de Pin C
000418 7300                          ANDI R16, 0b00110000
000419 9110 010b                     LDS R17, ESTADO							// Cargar ESTADO en R17
                                 
                                 	// Revisar botón de incremento respecto a su estado anterior
00041b ff14                          SBRS R17, 4
00041c c005                          RJMP CHEQUEO
00041d fd04                          SBRC R16, 4				
00041e c003                          RJMP CHEQUEO
                                 
                                 	// Encender bandera Incrementar
00041f e011                          LDI	R17, 0x01		
000420 9310 010f                     STS INCREMENTAR, R17		
                                 
                                 // Revisar botón de decremento respecto a su estado anterior
                                 CHEQUEO:
000422 9110 010b                     LDS R17, ESTADO			
000424 ff15                          SBRS R17, 5				
000425 c005                          RJMP GUARDAR
000426 fd05                          SBRC R16, 5				
000427 c003                          RJMP GUARDAR
                                 
                                 	// Encender bandera Decrementar
000428 e011                          LDI	R17, 0x01			
000429 9310 0110                     STS DECREMENTAR, R17
                                 
                                 // Guardar estado de botones
                                 GUARDAR:
00042b 9300 010b                     STS ESTADO, R16
00042d 910f                      	POP R16
00042e bf0f                      	OUT SREG, R16							// Devolver valores de SREG
00042f 9518                      	RETI
                                 
                                 // ISR Timer0
                                 TMR0_ISR:
000430 930f                      	PUSH	R16								// Guardar valor de R16
000431 b70f                      	IN		R16, SREG						
000432 930f                      	PUSH	R16								// Guardar valores de SREG
000433 931f                      	PUSH	R17								// Guardar valor de R17
                                 	// Recarga de timer
000434 e006                      	LDI		R16, TMR0_VALUE
000435 bd06                      	OUT		TCNT0, R16
                                 	// Encender bandera para multiplexión
000436 e001                      	LDI		R16, 0x01
000437 9300 010e                 	STS		MULTIPLEXION, R16
                                 // Salida de ISR
                                 EXIT_TMR0_ISR:
000439 911f                      	POP		R17								// Devolver valor de R17
00043a 910f                      	POP		R16								
00043b bf0f                      	OUT		SREG, R16						// Devolver valor de SREG
00043c 910f                      	POP		R16								// Devolver valor de R16
00043d 9518                      	RETI
                                 
                                 // ISR Timer1
                                 TMR1_ISR:
00043e 930f                      	PUSH	R16								// Guardar valor de R16
00043f b70f                      	IN		R16, SREG						
000440 930f                      	PUSH	R16								// Guardar valores de SREG
000441 931f                      	PUSH	R17								// Guardar valor de R17
                                 	// Recargar timer
000442 e805                      	LDI		R16, HIGH(TMR1_VALUE)
000443 9300 0085                 	STS		TCNT1H, R16
000445 ee0e                      	LDI		R16, LOW(TMR1_VALUE)
000446 9300 0084                 	STS		TCNT1L, R16
                                 	// Parpadeo dos puntos
000448 e800                      	LDI		R16, 0b10000000
000449 2790                      	EOR		PUNTO, R16
                                 	// Espera de 60 segundos
00044a 9100 010a                 	LDS		R16, TIEMPO
00044c 9503                      	INC		R16								// Aumentar contador TIEMPO
00044d 3708                      	CPI		R16, 120						// Revisar si TIEMPO llegó a 120
00044e f421                      	BRNE	EXIT_TMR1_ISR
                                 	// Encender bandera para contar
00044f e001                      	LDI		R16, 0x01
000450 9300 010d                 	STS		CONTAR, R16
000452 2700                      	CLR		R16
                                 // Salida de ISR
                                 EXIT_TMR1_ISR:
000453 9300 010a                 	STS	TIEMPO, R16							// Guardar valor de TIEMPO
000455 911f                      	POP	R17									// Devolver valor de R17
000456 910f                      	POP R16
000457 bf0f                      	OUT SREG, R16							// Devolver valor de SREG
000458 910f                      	POP R16									// Devolver valor de R16
000459 9518                      	RETI
                                 


